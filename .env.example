# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Public URL of this server as reached by MCP clients (HTTPS in production).
# Used to build the OAuth discovery metadata and the /callback redirect
# registered in the Entra ID app.
BASE_URL=https://outlook-mcp.example.com

# Port the HTTP server listens on inside the container
PORT=3000

# Long random string used to sign the OAuth state that travels through the
# Microsoft login round-trip. Generate one with: openssl rand -hex 32
STATE_SECRET=change-me-to-a-long-random-string

# Optional: restrict which hosts may receive the OAuth redirect after login
# (comma-separated). Empty = any HTTPS redirect_uri (PKCE still applies).
# OAUTH_ALLOWED_REDIRECT_HOSTS=claude.ai,claude.com

# ---------------------------------------------------------------------------
# Microsoft Entra ID app registration (Azure Portal > App registrations)
# ---------------------------------------------------------------------------

# Application (client) ID
OUTLOOK_CLIENT_ID=your-client-id-here

# Client secret VALUE (only if the app is registered as a confidential "Web"
# client; leave empty for a public client using PKCE)
OUTLOOK_CLIENT_SECRET=

# OAuth audience — must match the app registration's "Supported account types":
#   common         — personal AND work/school accounts (default)
#   consumers      — personal Microsoft accounts only
#   organizations  — work/school accounts only
#   <tenant-guid>  — single-tenant
# OUTLOOK_AUTH_AUDIENCE=common

# ---------------------------------------------------------------------------
# Optional behaviour / safety controls
# ---------------------------------------------------------------------------

# Enable test mode with mock data (true/false)
# USE_TEST_MODE=false

# Maximum emails that can be sent per server session (0 = unlimited)
# OUTLOOK_MAX_EMAILS_PER_SESSION=10

# Restrict sending to specific domains/addresses (comma-separated)
# OUTLOOK_ALLOWED_RECIPIENTS=mycompany.com,partner@example.com

# Enable immutable IDs (IDs persist through folder moves)
# OUTLOOK_IMMUTABLE_IDS=true

# Default timezone for calendar events (IANA identifier)
# OUTLOOK_DEFAULT_TIMEZONE=America/Sao_Paulo
